{
  "name": "sendex",
  "version": "0.3.2",
  "description": "A lightweight API endpoint testing tool",
  "main": "./bin/index.js",
  "bin": {
    "sendex": "./bin/index.js"
  },
  "scripts": {
    "create": "npm run build && npm run test",
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "local": "npm run build && node ./bin/index.js",
    "test": "jest --verbose ./tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hadlow/sendex.git"
  },
  "keywords": [
    "api",
    "endpoint",
    "rest",
    "test"
  ],
  "author": "Billy Hadlow <me@billyhadlow.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hadlow/sendex/issues"
  },
  "homepage": "https://www.sendexapi.com",
  "dependencies": {
    "axios": "^0.21.1",
    "chalk": "^4.1.0",
    "clear": "^0.1.0",
    "commander": "^6.1.0",
    "dotenv": "^10.0.0",
    "path": "^0.12.7",
    "yaml": "^1.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@babel/preset-env": "^7.16.4",
    "@babel/preset-typescript": "^7.16.0",
    "@types/jest": "^27.0.3",
    "@types/node": "^14.11.2",
    "babel-jest": "^27.3.1",
    "jest": "^27.3.1",
    "mock-fs": "^5.1.2",
    "ts-node": "^9.1.1",
    "typescript": "^4.0.3"
  }
}
